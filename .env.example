# ─── Google Cloud / Service Account ─────────────────────────────────────────
# Path to the service account JSON file (avoids newline issues with inline JSON)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=~/.nobi/service_account.json
# Alternative: inline JSON (not recommended — PEM newlines break bash sourcing)
# GOOGLE_SERVICE_ACCOUNT_JSON=

# ─── Google Search Console ───────────────────────────────────────────────────
SEARCH_CONSOLE_SITE_URL=sc-domain:nobi.ai
SEARCH_CONSOLE_DAYS_BACK=90
SEARCH_CONSOLE_MIN_IMPRESSIONS=10

# ─── BigQuery ────────────────────────────────────────────────────────────────
BQ_PROJECT=locusive-production
NOBI_MERCHANT_ID=460cbe82-9195-424f-a616-b1cb3e3caca0
BQ_DAYS_BACK=90
BQ_MIN_COUNT=2

# ─── Google Ads ──────────────────────────────────────────────────────────────
# Path to google-ads.yaml (generated by scripts/utils/google_ads_oauth.py)
GOOGLE_ADS_YAML=~/.nobi/google-ads.yaml
# MCC manager account customer ID (no dashes)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=9371001674
# Data account to query (no dashes); defaults to login ID if not set
GOOGLE_ADS_CUSTOMER_ID=2436855146
# For OAuth script only (not needed at runtime):
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_DEVELOPER_TOKEN=
